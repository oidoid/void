{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oidoid.github.io/void/config-file.v0.json",
  "title": "void Config File Schema",
  "type": "object",
  "description": "a JSON representation of a void config file.",
  "$defs": {
    "Atlas": {
      "type": "object",
      "description": "spritesheet config.",
      "required": ["dir", "image"],
      "properties": {
        "dir": {
          "type": "string",
          "description": "Aseprite asset root directory. all `**.aseprite` files are input.",
          "examples": ["src/assets/atlas/", "./"]
        },
        "image": {
          "type": "string",
          "description": "spritesheet image output.",
          "examples": ["dist/public/atlas.webp", "atlas.png"]
        }
      }
    },
    "Tileset": {
      "type": "object",
      "description": "tileset config.",
      "required": ["dir", "image"],
      "properties": {
        "dir": {
          "type": "string",
          "description": "Aseprite tileset root directory. all `**.aseprite` files are input.",
          "examples": ["src/assets/tileset/", "./"]
        },
        "image": {
          "type": "string",
          "description": "tileset image output.",
          "examples": ["dist/public/tileset.webp", "tileset.png"]
        }
      }
    }
  },
  "required": ["atlas", "out"],
  "unevaluatedProperties": false,
  "properties": {
    "out": {
      "type": "object",
      "description": "output config.",
      "required": ["game", "tagSchema"],
      "unevaluatedProperties": false,
      "properties": {
        "game": {
          "type": "string",
          "description": "game config output.",
          "examples": ["src/assets/void.game.json", "void.game.json"]
        },
        "name": {
          "type": "string",
          "description": "HTML output file stem when watch is disabled. defaults to entry.",
          "examples": ["index", "super-patience"]
        },
        "tagSchema": {
          "type": "string",
          "description": "tag schema.",
          "examples": ["src/level/tags.json"]
        }
      }
    },
    "atlas": {"$ref": "#/$defs/Atlas", "unevaluatedProperties": false},
    "tileset": {"$ref": "#/$defs/Tileset", "unevaluatedProperties": false},
    "input": {
      "description": "button mapping. defaults to init all default buttons, custom to leave all unmapped.",
      "enum": ["Default", "Unmapped"],
      "$comment": "to-do: support custom mapping here."
    },
    "mode": {
      "description": "use fractional or integral rendering.",
      "enum": ["Int", "Float"]
    }
  }
}
