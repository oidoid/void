{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Ent": {
      "allOf": [
        {"$ref": "level-file.v0.json#/$defs/Ent"},
        {
          "type": "object",
          "properties": {
            "loadConfig": {
              "$ref": "#/$defs/LoadConfig",
              "unevaluatedProperties": false
            },
            "loadLevel": {
              "$ref": "#/$defs/LoadLevel",
              "unevaluatedProperties": false
            },
            "loadTileset": {
              "$ref": "#/$defs/LoadTileset",
              "unevaluatedProperties": false
            }
          }
        }
      ]
    },
    "LoadConfig": {
      "type": "object",
      "description": "load game config button config."
    },
    "LoadLevel": {
      "type": "object",
      "description": "load level button config."
    },
    "LoadTileset": {
      "type": "object",
      "description": "load tileset button config."
    }
  }
}
